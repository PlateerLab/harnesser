# ── Harnesser 환경 설정 ─────────────────────────────────────────────
# cp .env.example .env 후 값을 채우세요. (없어도 기본값으로 기동됩니다)

# 데이터베이스
POSTGRES_PASSWORD=harnesser

# 보안 (운영 배포 시 반드시 교체: openssl rand -hex 32)
JWT_SECRET=harnesser-dev-secret-change-me
INTERNAL_TOKEN=harnesser-internal-change-me

# 포트
WEB_PORT=3000
API_PORT=8000

# 데모 계정/문제 시드 (최초 기동 시 1회, 운영에서는 false 권장)
SEED_DEMO_DATA=true

# ── AI (OpenAI 호환 엔드포인트: OpenAI / Anthropic compat / vLLM / 사내 게이트웨이) ──
# 비워두면 AI 활용 테스트의 채팅과 자동평가가 "미설정" 상태로 동작합니다.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini
AI_EVAL_MODEL=gpt-4o-mini

# 채점 워커 동시 실행 수
JUDGE_CONCURRENCY=2
